datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 String               @id @default(uuid())
  email              String               @unique
  passwordHash       String               @map("password_hash")
  name               String
  role               String               @default("Employee") // Admin, Asset_Manager, Department_Head, Employee
  isActive           Boolean              @default(true) @map("is_active")
  deletedAt          DateTime?            @map("deleted_at")
  departmentId       String?              @map("department_id")
  department         Department?          @relation("UserDepartment", fields: [departmentId], references: [id], onDelete: SetNull)
  
  // Audits assigned to this user
  auditedCycles      AuditCycle[]         @relation("AuditorRelation")
  
  // Relations
  allocations        AssetAllocation[]
  transferRequests   TransferRequest[]    @relation("TransferRequester")
  transferApprovals  TransferRequest[]    @relation("TransferApprover")
  bookings           ResourceBooking[]
  raisedMaintenance  MaintenanceRequest[] @relation("MaintenanceRequester")
  assignedMaintenance MaintenanceRequest[] @relation("MaintenanceTechnician")
  auditLogs          AuditLog[]
  notifications      Notification[]
  
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  @@index([email])
  @@index([departmentId])
  @@map("users")
}

model Department {
  id               String            @id @default(uuid())
  name             String            @unique
  isActive         Boolean           @default(true) @map("is_active")
  deletedAt        DateTime?         @map("deleted_at")
  
  parentDepartmentId String?         @map("parent_department_id")
  parentDepartment   Department?     @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id], onDelete: SetNull)
  subDepartments     Department[]    @relation("DepartmentHierarchy")
  
  // Department head
  managerId        String?           @unique @map("manager_id")
  
  members          User[]            @relation("UserDepartment")
  allocations      AssetAllocation[]
  
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  @@index([parentDepartmentId])
  @@map("departments")
}

model AssetCategory {
  id             String   @id @default(uuid())
  name           String   @unique
  description    String?
  // Schema/fields for category-specific variables (stored as JSON)
  // e.g. {"warranty_months": 24, "fuel_type": "Diesel"}
  customFields   String?  @map("custom_fields") // SQLite JSON support can be mapped as string/text
  deletedAt      DateTime? @map("deleted_at")
  
  assets         Asset[]
  
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("asset_categories")
}

model Asset {
  id                 String               @id @default(uuid())
  name               String
  categoryId         String               @map("category_id")
  category           AssetCategory        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  assetTag           String               @unique @map("asset_tag") // AF-0001
  serialNumber       String?              @map("serial_number")
  acquisitionDate    DateTime?            @map("acquisition_date")
  acquisitionCost    Float?               @map("acquisition_cost") // Map Decimal to Float for SQLite
  condition          String               @default("New") // New, Good, Fair, Poor, Damaged
  location           String?
  isShared           Boolean              @default(false) @map("is_shared") // Can be booked as resource
  status             String               @default("Available") // Available, Allocated, Reserved, Under_Maintenance, Lost, Retired, Disposed
  photoUrl           String?              @map("photo_url")
  documentUrls       String?              @map("document_urls") // Stringified array
  deletedAt          DateTime?            @map("deleted_at")
  
  allocations        AssetAllocation[]
  bookings           ResourceBooking[]
  maintenanceRequests MaintenanceRequest[]
  auditRecords       AuditRecord[]
  
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  @@index([categoryId])
  @@index([status])
  @@index([assetTag])
  @@map("assets")
}

model AssetAllocation {
  id               String            @id @default(uuid())
  assetId          String            @map("asset_id")
  asset            Asset             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  userId           String?           @map("user_id") // Assigned to Employee
  user             User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  departmentId     String?           @map("department_id") // Assigned to Department
  department       Department?       @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  allocatedDate    DateTime          @default(now()) @map("allocated_date")
  expectedReturnDate DateTime?       @map("expected_return_date")
  returnedDate     DateTime?         @map("returned_date")
  checkinNotes     String?           @map("checkin_notes")
  isActive         Boolean           @default(true) @map("is_active")
  
  transferRequests TransferRequest[]
  
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  @@index([assetId])
  @@index([userId])
  @@index([departmentId])
  @@index([isActive])
  @@map("asset_allocations")
}

model TransferRequest {
  id                String          @id @default(uuid())
  allocationId      String          @map("allocation_id")
  allocation        AssetAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  requestedById     String          @map("requested_by_id")
  requestedBy       User            @relation("TransferRequester", fields: [requestedById], references: [id], onDelete: Cascade)
  targetUserId      String?         @map("target_user_id")
  targetDepartmentId String?        @map("target_department_id")
  status            String          @default("Requested") // Requested, Approved, Rejected
  approvedById      String?         @map("approved_by_id")
  approvedBy        User?           @relation("TransferApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  notes             String?
  
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  @@index([allocationId])
  @@index([requestedById])
  @@index([status])
  @@map("transfer_requests")
}

model ResourceBooking {
  id          String        @id @default(uuid())
  assetId     String        @map("asset_id") // Asset must be isShared = true
  asset       Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  userId      String        @map("user_id")
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  startTime   DateTime      @map("start_time")
  endTime     DateTime      @map("end_time")
  status      String        @default("Upcoming") // Upcoming, Ongoing, Completed, Cancelled
  notes       String?
  
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([assetId])
  @@index([userId])
  @@index([startTime, endTime])
  @@map("resource_bookings")
}

model MaintenanceRequest {
  id               String              @id @default(uuid())
  assetId          String              @map("asset_id")
  asset            Asset               @relation(fields: [assetId], references: [id], onDelete: Cascade)
  requesterId      String              @map("requester_id")
  requester        User                @relation("MaintenanceRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  issueDescription String              @map("issue_description")
  priority         String              @default("Medium") // Low, Medium, High, Critical
  status           String              @default("Pending") // Pending, Approved, Rejected, Technician_Assigned, In_Progress, Resolved
  assignedToId     String?             @map("assigned_to_id") // Technician
  assignedTo       User?               @relation("MaintenanceTechnician", fields: [assignedToId], references: [id], onDelete: SetNull)
  photoUrl         String?             @map("photo_url")
  resolutionNotes  String?             @map("resolution_notes")
  
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  @@index([assetId])
  @@index([requesterId])
  @@index([status])
  @@map("maintenance_requests")
}

model AuditCycle {
  id           String        @id @default(uuid())
  name         String
  startDate    DateTime      @map("start_date")
  endDate      DateTime      @map("end_date")
  isActive     Boolean       @default(true) @map("is_active")
  isClosed     Boolean       @default(false) @map("is_closed")
  
  auditors     User[]        @relation("AuditorRelation")
  records      AuditRecord[]
  
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@map("audit_cycles")
}

model AuditRecord {
  id           String      @id @default(uuid())
  cycleId      String      @map("cycle_id")
  cycle        AuditCycle  @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  assetId      String      @map("asset_id")
  asset        Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
  status       String      // Verified, Missing, Damaged
  notes        String?
  
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  @@index([cycleId])
  @@index([assetId])
  @@map("audit_records")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   String?
  
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}
